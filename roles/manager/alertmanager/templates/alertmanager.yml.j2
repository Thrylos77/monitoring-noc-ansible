global:
  resolve_timeout: 5m

route:
  group_by: ['alertname', 'severity']
  group_wait:      30s
  group_interval:  5m
  repeat_interval: 4h
  receiver: default
  routes:
    - match:
        severity: P1
      receiver: critique
      repeat_interval: 30m
    - match:
        severity: P2
      receiver: warning
    - match:
        severity: P3
      receiver: default
    - match:
        severity: P4
      receiver: default

inhibit_rules:
  - source_match:
      severity: P1
    target_match:
      severity: P2
    equal: ['host']

receivers:
  - name: default
    email_configs:
      - to: "noc@exemple.com"
        from: "alertmanager@exemple.com"
        smarthost: "smtp.exemple.com:587"

  - name: critique
    email_configs:
      - to: "sre@exemple.com"
        from: "alertmanager@exemple.com"
        smarthost: "smtp.exemple.com:587"
        send_resolved: true

  - name: warning
    email_configs:
      - to: "noc@exemple.com"
        from: "alertmanager@exemple.com"
        smarthost: "smtp.exemple.com:587"
